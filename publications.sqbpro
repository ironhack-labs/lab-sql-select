ndex="3" value="37"/><column index="4" value="79"/><column index="5" value="43"/><column index="6" value="46"/><column index="7" value="46"/><column index="8" value="159"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="stores" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="48"/><column index="2" value="295"/><column index="3" value="159"/><column index="4" value="79"/><column index="5" value="38"/><column index="6" value="47"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="titles" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="55"/><column index="2" value="300"/><column index="3" value="103"/><column index="4" value="46"/><column index="5" value="63"/><column index="6" value="87"/><column index="7" value="49"/><column index="8" value="63"/><column index="9" value="300"/><column index="10" value="159"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT title, rental_rate as cost, length
FROM film;

SELECT title, rental_rate/length as price_per_min FROM film
order by price_per_min desc;

select concat(title,', rating:', rating) as descriptor from film;

SELECT * from film 
where rental_duration BETWEEN 1 and 5;

SELECT a.first_name,
	   a.last_name,
	   f.title
FROM actor a
INNER join film_actor fa on a.actor_id = fa.actor_id
inner join film f on fa.film_id = f.film_id
limit 100;

SELECT first_name, last_name, count(*) films
FROM actor a
JOIN film_actor fa USING(actor_id) -- Using if the columns are identical
group by actor_id, first_name, last_name
order by films DESC
limit 1;

-- Challenge 1
-- Inner Join title from film &amp; inventory_id from inventory

SELECT f.title, i.inventory_id 
from film f
INNER JOIN inventory i on f.film_id = i.film_id;

-- Left join: Keeps everything from the left table. Even if there's no match to the RIGHT
SELECT f.title, count(r.rental_id) as rental_count
FROM film f
LEFT JOIN inventory i on f.film_id = i.film_id
LEFT JOIN rental r on i.inventory_id = r.inventory_id
GROUP by f.title
ORDER by rental_count ASC;

-- RIGHT join keeps everythin form the RIGHT TABLE
SELECT a.address, c.first_name, c.last_name
FROM customer c
RIGHT JOIN address a on c.address_id = a.address_id
WHERE c.customer_id is null;

--SUBQUERIES
SELECT first_name, last_name FROM actor
INNER JOIN 
		(SELECT DISTINCT actor_id FROM film_actor
		INNER JOIN
			(SELECT * FROM film
			 WHERE length &gt; (
				SELECT avg(length) 
				as average FROM film)
				) as selected_film_id
			on film_actor.film_id = selected_film_id.film_id) as selected_actors
on actor.actor_id = selected_actor.actor_id;
</sql><sql name="solutions.sql" filename="C:/Ironhack/lab-sql-select/solutions.sql">-- Reference to file &quot;C:/Ironhack/lab-sql-select/solutions.sql&quot; (not supported by this version) --</sql><current_tab id="1"/></tab_sql></sqlb_project>
